<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Show Student Data</title>
</head>

<body>

    <table border="1">

        <tr>
            <td>FirstName</td>
            <td>LastName</td>
                <td>Operation</td>
        </tr>

        <% data.forEach(student => { %>
            <tr>
                <td><%= student.FirstName %></td>
                <td><%= student.LastName %></td>

                 <td><a href="/ui/delete/<%=  student._id %>">Delete</a></td>
         
            </tr>
        <% }) %>

    </table>

</body>

</html>